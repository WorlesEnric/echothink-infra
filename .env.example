###############################################################################
# EchoThink Infrastructure - Environment Configuration
# Copy to .env and run `make init` to generate secrets
###############################################################################

# =============================================================================
# General
# =============================================================================
# Domain for service routing (e.g., example.com or localhost for dev)
DOMAIN=localhost
# Set public-facing service URLs to https://... when deploying behind FRP/reverse proxy.

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Per-service database passwords
SUPABASE_DB_PASSWORD=CHANGE_ME_SUPABASE_DB_PASSWORD
HATCHET_DB_PASSWORD=CHANGE_ME_HATCHET_DB_PASSWORD
LANGFUSE_DB_PASSWORD=CHANGE_ME_LANGFUSE_DB_PASSWORD
N8N_DB_PASSWORD=CHANGE_ME_N8N_DB_PASSWORD
DIFY_DB_PASSWORD=CHANGE_ME_DIFY_DB_PASSWORD
OUTLINE_DB_PASSWORD=CHANGE_ME_OUTLINE_DB_PASSWORD
LITELLM_DB_PASSWORD=CHANGE_ME_LITELLM_DB_PASSWORD
GITLAB_DB_PASSWORD=CHANGE_ME_GITLAB_DB_PASSWORD

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# MinIO (S3-compatible object storage)
# =============================================================================
MINIO_ROOT_USER=echothink-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000

# =============================================================================
# Supabase
# =============================================================================
# JWT secret used to sign/verify tokens (min 32 chars)
SUPABASE_JWT_SECRET=CHANGE_ME_SUPABASE_JWT_SECRET

# Pre-generated JWT tokens (generated by init.sh using JWT_SECRET)
SUPABASE_ANON_KEY=CHANGE_ME_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_REALTIME_SECRET_KEY_BASE=CHANGE_ME_SUPABASE_REALTIME_SECRET_KEY_BASE

# Supabase service URLs
SUPABASE_PUBLIC_URL=http://supabase.localhost
SUPABASE_SITE_URL=http://studio.localhost
SUPABASE_DB_URL=postgresql://supabase_admin:${SUPABASE_DB_PASSWORD}@postgres:5432/supabase

# =============================================================================
# =============================================================================

# =============================================================================
# LiteLLM (LLM Gateway)
# =============================================================================
LITELLM_MASTER_KEY=CHANGE_ME_LITELLM_MASTER_KEY

# LLM Provider API Keys
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# AZURE_API_KEY=
# AZURE_API_BASE=

# =============================================================================
# Langfuse (LLM Observability)
# =============================================================================
LANGFUSE_SECRET_KEY=CHANGE_ME_LANGFUSE_SECRET_KEY
LANGFUSE_NEXT_AUTH_SECRET=CHANGE_ME_LANGFUSE_NEXT_AUTH_SECRET
LANGFUSE_SALT=CHANGE_ME_LANGFUSE_SALT
LANGFUSE_PUBLIC_URL=http://langfuse.localhost

# =============================================================================
# n8n (Workflow Automation)
# =============================================================================
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY
N8N_WEBHOOK_URL=http://n8n.localhost
N8N_EDITOR_BASE_URL=http://n8n.localhost
N8N_HOST=n8n.localhost
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_PROXY_HOPS=1

# =============================================================================
# Dify (AI Application Builder)
# =============================================================================
DIFY_SECRET_KEY=CHANGE_ME_DIFY_SECRET_KEY
DIFY_PUBLIC_URL=http://dify.localhost

# =============================================================================
# Outline (Knowledge Base)
# =============================================================================
OUTLINE_SECRET_KEY=CHANGE_ME_OUTLINE_SECRET_KEY
OUTLINE_UTILS_SECRET=CHANGE_ME_OUTLINE_UTILS_SECRET
OUTLINE_URL=http://outline.localhost
OUTLINE_FORCE_HTTPS=false

# =============================================================================
# GitLab
# =============================================================================
GITLAB_ROOT_PASSWORD=CHANGE_ME_GITLAB_ROOT_PASSWORD
GITLAB_SHARED_RUNNERS_TOKEN=CHANGE_ME_GITLAB_RUNNERS_TOKEN
GITLAB_EXTERNAL_URL=http://gitlab.localhost
GITLAB_FORWARDED_PROTO=http
GITLAB_FORWARDED_SSL=off

# =============================================================================
# Hatchet (Task Orchestration)
# =============================================================================
HATCHET_CLIENT_TOKEN=CHANGE_ME_HATCHET_CLIENT_TOKEN
HATCHET_JWT_SECRET=CHANGE_ME_HATCHET_JWT_SECRET
HATCHET_AUTH_COOKIE_SECRETS=CHANGE_ME_HATCHET_AUTH_COOKIE_SECRETS
HATCHET_ENCRYPTION_MASTER_KEYSET=CHANGE_ME_HATCHET_ENCRYPTION_MASTER_KEYSET
HATCHET_ENCRYPTION_JWT_PRIVATE_KEYSET=CHANGE_ME_HATCHET_ENCRYPTION_JWT_PRIVATE_KEYSET
HATCHET_ENCRYPTION_JWT_PUBLIC_KEYSET=CHANGE_ME_HATCHET_ENCRYPTION_JWT_PUBLIC_KEYSET

# =============================================================================
# SMTP (Email delivery)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

SUPABASE_LOGFLARE_PUBLIC_ACCESS_TOKEN=pk_placeholder
SUPABASE_LOGFLARE_PRIVATE_ACCESS_TOKEN=sk_placeholder
SUPABASE_DASHBOARD_PASSWORD=password
REDIS_PASSWORD=password
