# Dify Application Configuration
# This file contains Dify-specific settings loaded via env_file

# --- Core Application ---
FLASK_ENV=production
EDITION=SELF_HOSTED
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO

# --- Security ---
SECRET_KEY=${DIFY_SECRET_KEY}
INIT_PASSWORD=${DIFY_INIT_PASSWORD:-changeme}

# --- File Upload ---
UPLOAD_FILE_SIZE_LIMIT=15
UPLOAD_FILE_BATCH_LIMIT=5
UPLOAD_IMAGE_FILE_SIZE_LIMIT=10

# --- Web Application ---
WEB_API_CORS_ALLOW_ORIGINS=*
CONSOLE_CORS_ALLOW_ORIGINS=*

# --- Mail (disabled by default) ---
MAIL_TYPE=
MAIL_DEFAULT_SEND_FROM=

# --- Vector Store ---
# Using pgvecto-rs (shared Postgres instance with pgvector extension — no extra service needed)
VECTOR_STORE=pgvecto-rs
PGVECTO_RS_DATABASE_URL=postgresql://dify_user:${DIFY_DB_PASSWORD}@postgres:5432/dify

# --- Dataset ---
ETL_TYPE=dify
UNSTRUCTURED_API_URL=

# --- Indexing ---
INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=1000

# --- Rate Limiting ---
API_TOOL_DEFAULT_CONNECT_TIMEOUT=10
API_TOOL_DEFAULT_READ_TIMEOUT=60

# --- Moderation ---
MODERATION_BUFFER_SIZE=300

# --- Workflow ---
WORKFLOW_MAX_EXECUTION_STEPS=500
WORKFLOW_MAX_EXECUTION_TIME=1200
WORKFLOW_CALL_MAX_DEPTH=5

# --- Code Execution Sandbox ---
CODE_EXECUTION_API_KEY=${DIFY_SANDBOX_API_KEY:-dify-sandbox-key}
CODE_MAX_NUMBER=9999999999999
CODE_MIN_NUMBER=-9999999999999
CODE_MAX_STRING_LENGTH=80000
CODE_MAX_STRING_ARRAY_LENGTH=30
CODE_MAX_OBJECT_ARRAY_LENGTH=30
CODE_MAX_NUMBER_ARRAY_LENGTH=1000

# --- HTTP Configuration ---
SSRF_PROXY_HTTP_URL=
SSRF_PROXY_HTTPS_URL=

# --- Multi-modal ---
MULTIMODAL_SEND_IMAGE_FORMAT=base64
